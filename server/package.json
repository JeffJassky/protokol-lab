{
  "name": "protokol-lab-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import ./src/instrument.js --watch src/index.js 2>&1 | tee /tmp/protokol-lab-server.log",
    "start": "node --import ./src/instrument.js src/index.js",
    "restore": "node src/scripts/restore.js",
    "cleanup:test-users": "node src/scripts/cleanup-test-users.js",
    "seed:demo-template": "node src/scripts/seed-demo-template.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.1",
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1035.0",
    "@google/genai": "^1.50.1",
    "@jeffjassky/marketing-admin": "file:../marketing",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.50.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@sentry/vue": "^10.50.0",
    "agenda": "^6.2.4",
    "agendash": "^8.2.2",
    "apns2": "^12.2.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.0",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.1.0",
    "web-push": "^3.6.7"
