node_modules
dist
dist-native

# Vendored @kyneticbio/core — populated by scripts/ensure-core.mjs as a
# symlink (local) or shallow clone (CI/DO). Never committed.
/core

.env
.env.local
.env.*.local

# Local database backups (mongodump output). Contain real user data —
# never commit.
.backups/
*.bson
client_secret_*.json
.DS_Store
*.app

# macOS Cmd+Shift+4 dumps these into whatever folder Finder is pointed at,
# which is often the repo root. They're never code and shouldn't ship.
Screenshot *.png
.claude/
plans/
test-results/
playwright-report/

# Capacitor / Xcode / Android Studio build artifacts. The platform shells
# (client/ios/, client/android/) are committed; their per-developer build
# outputs and IDE state are not.
client/ios/App/Pods/
client/ios/App/build/
client/ios/App/App.xcworkspace/xcuserdata/
client/ios/App/App.xcodeproj/xcuserdata/
client/ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
client/ios/DerivedData/
client/ios/.build/
client/android/build/
client/android/app/build/
client/android/.gradle/
client/android/.idea/
client/android/local.properties
client/android/captures/
client/android/app/release/
client/android/app/debug/
