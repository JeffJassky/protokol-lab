{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sitemap && vite build",
    "build:full": "npm run sitemap && npm run og && vite build && npm run prerender",
    "build:native": "VITE_APP_ONLY=1 vite build --outDir dist-native && node scripts/verify-native-bundle.mjs",
    "build:native:dev": "VITE_APP_ONLY=1 vite build --mode development --outDir dist-native && node scripts/verify-native-bundle.mjs",
    "build:native:sync": "npm run build:native && cap sync",
    "build:native:dev:sync": "npm run build:native:dev && cap sync",
    "ios:open": "cap open ios",
    "android:open": "cap open android",
    "prerender": "node scripts/prerender.mjs",
    "og": "node scripts/generate-og.mjs",
    "icons": "node scripts/generate-icons.js",
    "brand:extract": "node scripts/extract-pk-glyph.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/barcode-scanner": "^3.0.2",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-social-login": "^8.3.20",
    "@kyneticbio/core": "file:../core",
    "@sentry/capacitor": "^4.0.0",
    "@sentry/vite-plugin": "^5.2.0",
    "@sentry/vue": "10.43.0",
    "@unhead/vue": "^3.0.5",
    "@vueuse/core": "^14.2.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.1.0",
    "deep-chat": "^2.4.2",
    "floating-vue": "^5.2.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.30",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.4",
    "vue3-emoji-picker": "^1.1.8"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.8",
    "happy-dom": "^20.9.0",
    "opentype.js": "^1.3.4",
    "puppeteer": "^24.42.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.5"
  }
}
